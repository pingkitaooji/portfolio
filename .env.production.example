DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
DJANGO_ALLOWED_HOSTS=health.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://health.yourdomain.com
DJANGO_MEDIA_ROOT=/app/media
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1

CQCALLING_DEBUG=0
CQCALLING_SECRET_KEY=replace-with-a-long-random-cqcalling-secret
CQCALLING_ALLOWED_HOSTS=cqcalling.yourdomain.com
CQCALLING_SECURE_SSL_REDIRECT=0
CQCALLING_SESSION_COOKIE_SECURE=1
CQCALLING_CSRF_COOKIE_SECURE=1

PRIMERQC_DEBUG=0
PRIMERQC_SECRET_KEY=replace-with-a-long-random-primerqc-secret
PRIMERQC_ALLOWED_HOSTS=primerqc.yourdomain.com
PRIMERQC_SECURE_SSL_REDIRECT=0
PRIMERQC_SESSION_COOKIE_SECURE=1
PRIMERQC_CSRF_COOKIE_SECURE=1

POSTGRES_DB=healthrisk
POSTGRES_USER=healthrisk
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

DJANGO_SUPERUSER_USERNAME=clinic_admin
DJANGO_SUPERUSER_EMAIL=clinic@example.com
DJANGO_SUPERUSER_PASSWORD=replace-with-a-strong-admin-password
DJANGO_DEMO_LOGIN_PREFILL=0
CREATE_DEMO_USERS=0
